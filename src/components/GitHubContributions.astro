---
const username = "sandeshPatel06";
const chartUrl = `https://ghchart.rshah.org/9e59df/${username}`;
---

<section
    class="mt-8 p-5 bg-[var(--surface)] rounded-[12px]
  shadow-[0_10px_25px_rgba(0,0,0,0.2)] border border-[var(--card-border)]"
>
    <div
        class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-4"
    >
        <h2 class="mt-0 mb-0 text-[var(--text-soft)]">Contribution Activity</h2>
        <a
            href={`https://github.com/${username}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs text-[var(--accent)] no-underline hover:underline"
            >View on GitHub →</a
        >
    </div>

    <div id="contrib-count" class="text-sm text-[var(--text-muted)] mb-4"></div>

    <div
        class="w-full overflow-x-auto rounded-[8px] p-3 bg-[var(--surface-strong)] border border-[var(--card-border)]"
    >
        <img
            src={chartUrl}
            alt="GitHub contribution graph"
            class="w-full min-w-[600px] h-auto"
            style="border:none;border-radius:0;"
            loading="lazy"
        />
    </div>

    <div
        class="flex items-center gap-2 mt-3 justify-end text-xs text-[var(--text-muted)]"
    >
        <span>Less</span>
        <span
            class="w-3 h-3 rounded-sm"
            style="background:var(--surface-strong);border:1px solid var(--card-border)"
        ></span>
        <span class="w-3 h-3 rounded-sm" style="background:#9e59df33"></span>
        <span class="w-3 h-3 rounded-sm" style="background:#9e59df66"></span>
        <span class="w-3 h-3 rounded-sm" style="background:#9e59dfaa"></span>
        <span class="w-3 h-3 rounded-sm" style="background:#9e59df"></span>
        <span>More</span>
    </div>

    <div id="contrib-activity" class="mt-6 space-y-2"></div>
</section>

<script is:inline>
    (function () {
        const username = "sandeshPatel06";
        const fmt = (d) =>
            new Date(d).toLocaleDateString("en-US", {
                month: "long",
                day: "numeric",
                year: "numeric",
            });

        const typeLabel = {
            PushEvent: "Pushed commits",
            CreateEvent: "Created branch/repo",
            PullRequestEvent: "Pull request",
            IssuesEvent: "Issue opened",
            IssueCommentEvent: "Commented on issue",
            WatchEvent: "Starred a repo",
            ForkEvent: "Forked a repo",
            DeleteEvent: "Deleted branch/repo",
            ReleaseEvent: "Published a release",
            PublicEvent: "Made repo public",
        };

        const yearAgo = new Date();
        yearAgo.setFullYear(yearAgo.getFullYear() - 1);

        fetch(
            `https://api.github.com/users/${username}/events/public?per_page=100`,
        )
            .then((r) => r.json())
            .then((events) => {
                if (!Array.isArray(events)) return;

                const recentEvents = events.filter(
                    (e) => new Date(e.created_at) > yearAgo,
                );

                const countEl = document.getElementById("contrib-count");
                if (countEl) {
                    countEl.textContent = `${recentEvents.length}+ public events in the last year`;
                }

                const byDate = {};
                recentEvents.forEach((e) => {
                    const day = e.created_at.slice(0, 10);
                    if (!byDate[day]) byDate[day] = [];
                    byDate[day].push(e);
                });

                const actEl = document.getElementById("contrib-activity");
                if (!actEl) return;

                const sortedDays = Object.keys(byDate)
                    .sort((a, b) => b.localeCompare(a))
                    .slice(0, 10);

                actEl.innerHTML = sortedDays
                    .map((day) => {
                        const es = byDate[day];
                        const grouped = {};
                        es.forEach((e) => {
                            const label =
                                typeLabel[e.type] ||
                                e.type.replace("Event", "");
                            if (!grouped[label])
                                grouped[label] = {
                                    count: 0,
                                    repo: e.repo?.name || "",
                                };
                            grouped[label].count++;
                        });

                        const items = Object.entries(grouped)
                            .map(
                                ([label, { count, repo }]) =>
                                    `<span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full
                bg-[var(--surface)] border border-[var(--card-border)] text-[var(--text-soft)]">
                ${label}${count > 1 ? ` ×${count}` : ""}
              </span>`,
                            )
                            .join("");

                        return `
            <div class="flex flex-col gap-1.5">
              <div class="text-xs font-semibold text-[var(--text-muted)]">${fmt(day)}</div>
              <div class="flex flex-wrap gap-1.5">${items}</div>
            </div>`;
                    })
                    .join(
                        '<div class="border-t border-[var(--card-border)] my-3"></div>',
                    );
            })
            .catch(() => {});
    })();
</script>
