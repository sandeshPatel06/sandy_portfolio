---
import Icon from "./Icon.astro";

interface TimelineItem {
  period: string;
  tag: "Learning" | "Certification" | "Internship";
  title: string;
  org: string;
  description: string;
  icon: string;
  startMonth: number;
  durationMonths: number;
  buttonLabel?: string;
  onClickFn?: string;
}

const months = ["Apr", "May", "Jun", "Jul", "Aug", "Sep"];
const totalMonths = months.length;

const items: TimelineItem[] = [
  {
    period: "Apr 2024",
    tag: "Learning",
    title: "Learned HTML",
    org: "Self-Study",
    description:
      "Built a strong foundation in HTML — semantic markup, forms, tables, and structuring modern web pages from scratch.",
    icon: "html",
    startMonth: 0,
    durationMonths: 1,
  },
  {
    period: "May 2024",
    tag: "Learning",
    title: "Learned CSS",
    org: "Self-Study",
    description:
      "Developed responsive styling skills including Flexbox, Grid, animations, and cross-browser compatibility.",
    icon: "css",
    startMonth: 1,
    durationMonths: 1,
  },
  {
    period: "Jun 2024",
    tag: "Learning",
    title: "Basic JavaScript",
    org: "Self-Study",
    description:
      "Learned JavaScript fundamentals — DOM manipulation, events, fetch API, and building interactive web features.",
    icon: "javascript",
    startMonth: 2,
    durationMonths: 1,
  },
  {
    period: "Jul – Aug 2024",
    tag: "Learning",
    title: "Basic Python",
    org: "Self-Study",
    description:
      "Focused on logic-building, problem-solving, scripting, and automation fundamentals with Python.",
    icon: "python",
    startMonth: 3,
    durationMonths: 2,
  },
  {
    period: "Jul 2024",
    tag: "Certification",
    title: "Cybersecurity Fundamentals",
    org: "Online Certification",
    description:
      "Studied secure coding practices, network security basics, threat identification, and system protection methods.",
    icon: "code",
    startMonth: 3,
    durationMonths: 1,
  },
  {
    period: "Jul – Sep 2024",
    tag: "Internship",
    title: "Web Development Internship",
    org: "Next24Tech Technology & Services",
    description:
      "Completed hands-on frontend development — built responsive pages, collaborated on real client projects, and improved design skills.",
    icon: "folder",
    startMonth: 3,
    durationMonths: 3,
    buttonLabel: "View Certificate",
    onClickFn: "showImag()",
  },
  {
    period: "Aug – Sep 2024",
    tag: "Internship",
    title: "Machine Learning Internship",
    org: "Codetech IT Solutions",
    description:
      "Worked on ML tasks including data preprocessing, model training, and evaluation pipelines using Python and scikit-learn.",
    icon: "python",
    startMonth: 4,
    durationMonths: 2,
    buttonLabel: "View Certificate",
    onClickFn: "showImage()",
  },
];

const tagColors = {
  Learning: { bar: "#5b69e8", border: "border-[#5b69e8]/60 bg-[#5b69e8]/10" },
  Certification: {
    bar: "#9e59df",
    border: "border-[#9e59df]/60 bg-[#9e59df]/10",
  },
  Internship: { bar: "#059669", border: "border-[#059669]/60 bg-[#059669]/10" },
};
---

<section
  id="timeline"
  class="mt-8 p-5 bg-[var(--surface)] rounded-[12px]
  shadow-[0_10px_25px_rgba(0,0,0,0.2)] border border-[var(--card-border)]"
>
  <h2 class="mt-0 mb-6 text-[var(--text-soft)]">Past Experience</h2>

  <div class="relative">
    <div class="absolute left-6 top-0 bottom-0 w-px bg-[var(--card-border)]">
    </div>
    <div class="flex flex-col gap-6">
      {
        items.map((item) => (
          <div class="relative flex gap-5 pl-14">
            <div
              class="absolute left-0 w-12 h-12 rounded-full bg-[var(--surface-strong)]
                      border-2 border-[var(--accent)] flex items-center justify-center
                      text-[var(--accent)] shrink-0 z-10"
            >
              <Icon name={item.icon} size={22} />
            </div>
            <div
              class="flex-1 bg-[var(--surface-strong)] border border-[var(--card-border)]
                      rounded-[12px] p-4 hover:border-[var(--accent)] transition-colors"
            >
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span
                  class={`text-xs font-semibold px-2 py-0.5 rounded-full border text-[var(--text-soft)] ${tagColors[item.tag].border}`}
                >
                  {item.tag}
                </span>
                <span class="text-xs text-[var(--text-muted)]">
                  {item.period}
                </span>
              </div>
              <h3 class="mt-0 mb-0.5 text-[var(--text-soft)] text-[1rem] font-semibold">
                {item.title}
              </h3>
              <p class="text-xs text-[var(--accent)] font-medium mb-2 mt-0">
                {item.org}
              </p>
              <p class="text-[0.88rem] text-[var(--text-soft)] m-0 leading-relaxed">
                {item.description}
              </p>
              {item.buttonLabel && item.onClickFn && (
                <button
                  class="mt-3 inline-flex items-center gap-1.5 rounded-[8px] px-3 py-1.5
                       text-[0.82rem] font-semibold bg-[var(--accent)] text-white border-0
                       cursor-pointer transition-transform hover:-translate-y-0.5"
                  onclick={item.onClickFn}
                >
                  {item.buttonLabel}
                </button>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <div
    id="myModal"
    class="hidden fixed inset-0 z-[1600] bg-black/80 p-8"
    role="dialog"
    aria-modal="true"
    aria-label="Certificate preview"
  >
    <span
      class="absolute top-4 right-6 text-white text-4xl font-bold cursor-pointer leading-none"
      onclick="closeImage()">&times;</span
    >
    <img
      class="mt-16 mx-auto w-[min(90vw,720px)] max-h-[80vh] object-contain"
      id="modalImage"
      alt="Certificate"
    />
  </div>
</section>
