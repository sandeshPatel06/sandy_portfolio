---
import Icon from "./Icon.astro";

interface TimelineItem {
  period: string;
  tag: "Learning" | "Certification" | "Internship";
  title: string;
  org: string;
  description: string;
  icon: string;
  startMonth: number;
  durationMonths: number;
  buttonLabel?: string;
  onClickFn?: string;
}

const months = ["Apr", "May", "Jun", "Jul", "Aug", "Sep"];
const totalMonths = months.length;

const items: TimelineItem[] = [
  { period: "Apr 2024",      tag: "Learning",      title: "Learned HTML",                   org: "Self-Study",                      description: "Built a strong foundation in HTML — semantic markup, forms, tables, and structuring modern web pages from scratch.",                                                                     icon: "html",        startMonth: 0, durationMonths: 1 },
  { period: "May 2024",      tag: "Learning",      title: "Learned CSS",                    org: "Self-Study",                      description: "Developed responsive styling skills including Flexbox, Grid, animations, and cross-browser compatibility.",                                                                       icon: "css",         startMonth: 1, durationMonths: 1 },
  { period: "Jun 2024",      tag: "Learning",      title: "Basic JavaScript",               org: "Self-Study",                      description: "Learned JavaScript fundamentals — DOM manipulation, events, fetch API, and building interactive web features.",                                                                    icon: "javascript",  startMonth: 2, durationMonths: 1 },
  { period: "Jul – Aug 2024",tag: "Learning",      title: "Basic Python",                   org: "Self-Study",                      description: "Focused on logic-building, problem-solving, scripting, and automation fundamentals with Python.",                                                                                  icon: "python",      startMonth: 3, durationMonths: 2 },
  { period: "Jul 2024",      tag: "Certification", title: "Cybersecurity Fundamentals",     org: "Online Certification",            description: "Studied secure coding practices, network security basics, threat identification, and system protection methods.",                                                                   icon: "code",        startMonth: 3, durationMonths: 1 },
  { period: "Jul – Sep 2024",tag: "Internship",    title: "Web Development Internship",     org: "Next24Tech Technology & Services",description: "Completed hands-on frontend development — built responsive pages, collaborated on real client projects, and improved design skills.",                                             icon: "folder",      startMonth: 3, durationMonths: 3, buttonLabel: "View Certificate", onClickFn: "showImag()" },
  { period: "Aug – Sep 2024",tag: "Internship",    title: "Machine Learning Internship",    org: "Codetech IT Solutions",           description: "Worked on ML tasks including data preprocessing, model training, and evaluation pipelines using Python and scikit-learn.",                                                          icon: "python",      startMonth: 4, durationMonths: 2, buttonLabel: "View Certificate", onClickFn: "showImage()" },
];

const tagColors = {
  Learning:      { bar: "#5b69e8", bg: "bg-[#5b69e8]/20 border-[#5b69e8]/40 text-[#a0b0ff]" },
  Certification: { bar: "#9e59df", bg: "bg-[#9e59df]/20 border-[#9e59df]/40 text-[#d0a0ff]" },
  Internship:    { bar: "#059669", bg: "bg-[#059669]/20 border-[#059669]/40 text-[#6ee7b7]" },
};
---

<section id="timeline" class="mt-8 p-5 bg-[var(--surface)] rounded-[12px]
  shadow-[0_10px_25px_rgba(0,0,0,0.2)] border border-[var(--card-border)]">

  <h2 class="mt-0 mb-6 text-[var(--text-soft)]">Past Experience</h2>

  <div class="mb-8 overflow-x-auto">
    <div class="min-w-[480px]">

      <div class="flex gap-2 mb-2 pl-[140px]">
        {months.map((m) => (
          <div class="flex-1 text-center text-xs font-semibold text-[var(--text-muted)]">{m}</div>
        ))}
      </div>

      <div class="pl-[140px] mb-3 relative">
        {months.map((_, i) => (
          <div
            class="absolute top-0 bottom-0 border-l border-dashed border-[var(--card-border)]"
            style={`left: calc(${(i / totalMonths) * 100}%)`}
          ></div>
        ))}
      </div>

      <div class="flex flex-col gap-2">
        {items.map((item) => {
          const left  = (item.startMonth / totalMonths) * 100;
          const width = (item.durationMonths / totalMonths) * 100;
          const color = tagColors[item.tag].bar;
          return (
            <div class="flex items-center gap-3 group">
              <div class="w-[132px] shrink-0 flex items-center justify-end gap-1.5">
                <Icon name={item.icon} size={14} class="text-[var(--text-muted)] shrink-0" />
                <span class="text-xs text-[var(--text-soft)] truncate text-right">{item.title}</span>
              </div>
              <div class="relative flex-1 h-7 bg-[var(--surface-strong)] rounded-full border border-[var(--card-border)] overflow-hidden">
                <div
                  class="absolute top-[3px] bottom-[3px] rounded-full flex items-center justify-center text-[10px] font-bold text-white px-2 overflow-hidden whitespace-nowrap"
                  style={`left: calc(${left}% + 3px); width: calc(${width}% - 6px); background: ${color};`}
                >
                  {item.period}
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <div class="flex items-center gap-5 mt-4 flex-wrap pl-[140px]">
        {Object.entries(tagColors).map(([label, c]) => (
          <div class="flex items-center gap-1.5">
            <span class="w-3 h-3 rounded-sm" style={`background: ${c.bar}`}></span>
            <span class="text-xs text-[var(--text-muted)]">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="relative">
    <div class="absolute left-6 top-0 bottom-0 w-px bg-[var(--card-border)]"></div>
    <div class="flex flex-col gap-6">
      {items.map((item) => (
        <div class="relative flex gap-5 pl-14">
          <div class="absolute left-0 w-12 h-12 rounded-full bg-[var(--surface-strong)]
                      border-2 border-[var(--accent)] flex items-center justify-center
                      text-[var(--accent)] shrink-0 z-10">
            <Icon name={item.icon} size={22} />
          </div>
          <div class="flex-1 bg-[var(--surface-strong)] border border-[var(--card-border)]
                      rounded-[12px] p-4 hover:border-[var(--accent)] transition-colors">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class={`text-xs font-semibold px-2 py-0.5 rounded-full border ${tagColors[item.tag].bg}`}>
                {item.tag}
              </span>
              <span class="text-xs text-[var(--text-muted)]">{item.period}</span>
            </div>
            <h3 class="mt-0 mb-0.5 text-[var(--text-soft)] text-[1rem] font-semibold">{item.title}</h3>
            <p class="text-xs text-[var(--accent)] font-medium mb-2 mt-0">{item.org}</p>
            <p class="text-[0.88rem] text-[var(--text-soft)] m-0 leading-relaxed">{item.description}</p>
            {item.buttonLabel && item.onClickFn && (
              <button
                class="mt-3 inline-flex items-center gap-1.5 rounded-[8px] px-3 py-1.5
                       text-[0.82rem] font-semibold bg-[var(--accent)] text-white border-0
                       cursor-pointer transition-transform hover:-translate-y-0.5"
                onclick={item.onClickFn}
              >{item.buttonLabel}</button>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div id="myModal" class="hidden fixed inset-0 z-[1600] bg-black/80 p-8"
    role="dialog" aria-modal="true" aria-label="Certificate preview">
    <span class="absolute top-4 right-6 text-white text-4xl font-bold cursor-pointer leading-none"
      onclick="closeImage()">&times;</span>
    <img class="mt-16 mx-auto w-[min(90vw,720px)] max-h-[80vh] object-contain"
      id="modalImage" alt="Certificate" />
  </div>
</section>
