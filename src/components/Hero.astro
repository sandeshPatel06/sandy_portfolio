---
import Icon from "./Icon.astro";

const driveFileId = "1xfg6OyvaytkXQuqjgVhSyRAWkr4_91C1";
const previewUrl = `https://drive.google.com/file/d/${driveFileId}/preview`;
const downloadUrl = `https://drive.google.com/uc?export=download&id=${driveFileId}`;
---

<section
  id="home"
  class="grid grid-cols-1 md:grid-cols-[1.1fr_0.9fr] gap-8 items-center mt-4"
>
  <div class="text-center md:text-left">
    <h1 class="m-0 text-[clamp(2rem,6vw,3rem)] leading-[1.15] font-bold">
      <span class="text-[var(--accent)]">SANDESH PATEL</span>
    </h1>
    <p class="mt-3 mb-0 text-[var(--text-soft)]">
      And I am a passionate <span id="element"></span>
    </p>
    <div class="flex flex-wrap gap-3 mt-5 justify-center md:justify-start">
      <button
        id="resume-open-btn"
        class="inline-flex items-center gap-2 justify-center rounded-[10px] border border-transparent
               px-4 py-[0.65rem] text-[0.95rem] font-semibold cursor-pointer
               bg-[var(--accent-strong)] text-white transition-transform hover:-translate-y-0.5"
      >
        <Icon name="eye" size={17} />
        View Resume
      </button>
      <a
        target="_blank"
        rel="noopener noreferrer"
        href="https://github.com/sandeshPatel06?tab=repositories"
        class="inline-flex items-center gap-2 justify-center rounded-[10px]
               border border-[var(--card-border)] px-4 py-[0.65rem] text-[0.95rem] font-semibold
               no-underline cursor-pointer bg-[var(--surface-strong)] text-[var(--text)]
               transition-transform hover:-translate-y-0.5"
      >
        <Icon name="github" size={17} />
        Visit GitHub
      </a>
    </div>
  </div>
  <div class="flex justify-center">
    <img
      src="/img/hero-illustration.webp"
      alt="Illustration for Sandesh Patel portfolio"
      width="400"
      height="400"
      class="max-w-full h-auto"
    />
  </div>
</section>

<div
  id="resume-modal"
  class="hidden fixed inset-0 z-[1700] bg-black/80 flex items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Resume preview"
>
  <div
    class="relative w-full max-w-3xl bg-[var(--surface)] rounded-[14px] overflow-hidden
              shadow-[0_20px_60px_rgba(0,0,0,0.5)] flex flex-col"
    style="height: min(90vh, 720px);"
  >
    <div
      class="flex items-center justify-between px-5 py-3 border-b border-[var(--card-border)] shrink-0"
    >
      <span class="font-semibold text-[var(--text-soft)] text-sm"
        >Sandesh Patel — Resume</span
      >
      <div class="flex items-center gap-3">
        <a
          href={downloadUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-[0.82rem] font-semibold
                 bg-[var(--accent)] text-white no-underline hover:opacity-90 transition-opacity"
        >
          <Icon name="download" size={14} />
          Download
        </a>
        <button
          id="resume-close-btn"
          class="w-8 h-8 flex items-center justify-center rounded-lg bg-[var(--surface-strong)]
                 border border-[var(--card-border)] text-[var(--text)] cursor-pointer hover:border-[var(--accent)] transition-colors"
          aria-label="Close resume"
        >
          <Icon name="xmark" size={18} />
        </button>
      </div>
    </div>

    <iframe
      src={previewUrl}
      title="Sandesh Patel Resume"
      class="w-full flex-1 border-0"
      allow="autoplay"></iframe>
  </div>
</div>

<script is:inline>
  (function () {
    const modal = document.getElementById("resume-modal");
    const openBtn = document.getElementById("resume-open-btn");
    const closeBtn = document.getElementById("resume-close-btn");

    const open = () => {
      if (modal) {
        modal.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      }
    };
    const close = () => {
      if (modal) {
        modal.classList.add("hidden");
        document.body.style.overflow = "";
      }
    };

    openBtn?.addEventListener("click", open);
    closeBtn?.addEventListener("click", close);
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) close();
    });
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  })();
</script>
